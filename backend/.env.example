# .env.example
# Скопировать в .env и заполнить реальными значениями.
# .env НЕ коммитится в git (см. .dockerignore и .gitignore).

APP_ENV=production
DEBUG=false
APP_BASE_URL=https://reviewflow.kz

# --- Supabase Postgres ---
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis (внутри docker-сети — переопределяется на redis:// в docker-compose.yml) ---
REDIS_URL=redis://localhost:6379/0

# --- Green API (WhatsApp) ---
GREEN_API_INSTANCE_ID=CHANGE_ME
GREEN_API_TOKEN=CHANGE_ME

# --- OpenAI ---
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o-mini

# --- Telegram Bot API ---
TELEGRAM_BOT_TOKEN=CHANGE_ME

# --- Kaspi Pay ---
KASPI_PAY_MERCHANT_ID=CHANGE_ME
KASPI_PAY_API_KEY=CHANGE_ME

# --- Resend ---
RESEND_API_KEY=CHANGE_ME
RESEND_FROM_EMAIL=billing@reviewflow.kz

# --- Безопасность ---
# Генерировать так: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SIGNING_SECRET=CHANGE_ME
CORS_ALLOWED_ORIGINS=["https://reviewflow.kz","http://localhost:3000"]
